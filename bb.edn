{:tasks
 ;; Tests run via JVM clojure aliases (deps.edn :spec / :features). When
 ;; ../isaac-foundation exists, :dev-local overrides the pinned foundation dep
 ;; with the local sibling. Set ISAAC_GIT=1 to force the pinned git shas.
 {:init (def ^:private alias-prefix
          (if (and (not (System/getenv "ISAAC_GIT"))
                   (babashka.fs/exists? "../isaac-foundation"))
            "-M:dev-local"
            "-M"))

  spec     {:doc  "Run cli-proxy unit specs"
            :task (apply shell "clojure" (str alias-prefix ":spec") *command-line-args*)}

  features {:doc  "Run cli-proxy features (excludes @slow and @wip)"
            :task (do (babashka.fs/delete-tree "target")
                      (apply shell "clojure" (str alias-prefix ":features") *command-line-args*))}

  features-slow {:doc  "Run @slow integration features only"
                 :task (do (babashka.fs/delete-tree "target")
                           (apply shell "clojure" (str alias-prefix ":features:features-slow") *command-line-args*))}

  ci       {:doc  "Run all specs and features"
            :task (do (shell "bb" "spec")
                      (shell "bb" "features")
                      (shell "bb" "features-slow"))}

  clean    {:doc  "Remove the target/ build dir"
            :task (babashka.fs/delete-tree "target")}}}
