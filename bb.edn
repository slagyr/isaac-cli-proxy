{:paths ["src" "spec" "features"]

 ;; Native babashka runners via isaac-foundation-test-support (isaac-x5ru / isaac-fq28).
 ;; Keep the test-support :git/sha in sync with the foundation commit that
 ;; ships bb.test-tasks under spec-support/src/bb/. Product pins below match
 ;; the pre-xapx bb classpath (bump intentionally when ready).
 :deps  {io.github.slagyr/isaac-foundation              {:git/url "https://github.com/slagyr/isaac-foundation.git"
                                                          :git/sha "43cf46e00087bf066a9e065ccc3d48dd2814ac23"}
         io.github.slagyr/isaac-foundation-spec         {:git/url "https://github.com/slagyr/isaac-foundation.git"
                                                          :git/sha "43cf46e00087bf066a9e065ccc3d48dd2814ac23"
                                                          :deps/root "spec"}
         io.github.slagyr/isaac-foundation-test-support {:git/url "https://github.com/slagyr/isaac-foundation.git"
                                                          :git/sha "43cf46e00087bf066a9e065ccc3d48dd2814ac23"
                                                          :deps/root "spec-support"}
         io.github.slagyr/isaac-agent                     {:git/url "https://github.com/slagyr/isaac-agent.git"
                                                          :git/sha "153baa684c42c43bda46d5975e6f7f973a533568"}
         io.github.slagyr/isaac-agent-spec               {:git/url "https://github.com/slagyr/isaac-agent.git"
                                                          :git/sha "153baa684c42c43bda46d5975e6f7f973a533568"
                                                          :deps/root "spec"}
         io.github.slagyr/isaac-server                    {:git/url "https://github.com/slagyr/isaac-server.git"
                                                          :git/sha "dfa8767a440fc4c8b8bc6877ffd58ae20d028367"}
         io.github.slagyr/isaac-server-spec               {:git/url "https://github.com/slagyr/isaac-server.git"
                                                          :git/sha "dfa8767a440fc4c8b8bc6877ffd58ae20d028367"
                                                          :deps/root "spec"}
         io.github.slagyr/isaac-server-test-support       {:git/url "https://github.com/slagyr/isaac-server.git"
                                                          :git/sha "dfa8767a440fc4c8b8bc6877ffd58ae20d028367"
                                                          :deps/root "spec-support"}
         io.github.slagyr/isaac-cli-server                {:git/url "https://github.com/slagyr/isaac-cli-server.git"
                                                          :git/sha "8f42058034dfd9c5b3582d2edf27f75618f81992"}
         marigold.bridge/marigold.bridge                  {:git/url "https://github.com/slagyr/isaac-foundation.git"
                                                          :git/sha "43cf46e00087bf066a9e065ccc3d48dd2814ac23"
                                                          :deps/root "modules/marigold.bridge"}
         marigold.longwave/marigold.longwave              {:git/url "https://github.com/slagyr/isaac-foundation.git"
                                                          :git/sha "43cf46e00087bf066a9e065ccc3d48dd2814ac23"
                                                          :deps/root "modules/marigold.longwave"}
         clout/clout                                      {:mvn/version "1.1.0"}
         com.cleancoders.c3kit/apron                      {:mvn/version "3.0.0"}
         io.github.cleancoders/c3kit-wire                 {:git/tag "2.5.1" :git/sha "1fae444"}
         cheshire/cheshire                                {:mvn/version "5.13.0"}
         http-kit/http-kit                                {:mvn/version "2.8.0"}
         ring/ring-codec                                  {:mvn/version "1.2.0"}
         org.clojure/tools.cli                            {:mvn/version "1.1.230"}
         org.babashka/http-client                         {:mvn/version "0.4.22"}
         babashka/process                                 {:mvn/version "0.5.22"}
         speclj/speclj                                    {:mvn/version "3.13.0"}
         io.github.slagyr/gherclj                         {:git/tag "v1.3.0" :git/sha "9c3bb1d"}}

 :tasks
 {config-bypass-lint {:doc "Fail on raw config slurp/read outside isaac.config.* (isaac-foundation-test-support)"
                      :requires ([isaac.foundation.config-bypass-lint :as lint])
                      :task (apply lint/lint! (or (seq *command-line-args*) ["src"]))}

  spec {:doc  "Run cli-proxy unit specs natively (pass file/dir to narrow)"
        :requires ([babashka.process :as process])
        :task (let [args (vec *command-line-args*)
                    cmd  (into ["bb" "-e"
                                "(require '[bb.test-tasks :as t]) (apply t/run-spec! *command-line-args*)"
                                "--"]
                               args)
                    {:keys [exit]} (apply process/shell cmd)]
                (when (pos? exit) (System/exit exit)))}

  jvm-spec {:doc  "Run speclj via clojure -M:spec (JVM fallback)"
            :requires ([bb.test-tasks :as tests])
            :task (binding [tests/*jvm-spec-cmd* ["clojure" "-M:spec"]]
                    (apply tests/run-jvm-spec! *command-line-args*))}

  features {:doc  "Run cli-proxy features natively (excludes @slow and @wip)"
            :requires ([babashka.process :as process])
            :task (let [args (vec *command-line-args*)
                        expr (str "(require '[bb.test-tasks :as t]) "
                                  "(binding [t/*step-globs* "
                                  "[\"isaac.**-steps\" \"isaac.cli-proxy.feature-bootstrap\"]] "
                                  "(apply t/run-features! *command-line-args*))")
                        cmd  (into ["bb" "-e" expr "--"] args)
                        {:keys [exit]} (apply process/shell cmd)]
                    (when (pos? exit) (System/exit exit)))}

  features-slow {:doc  "Run @slow integration features natively"
                 :requires ([babashka.process :as process])
                 :task (let [args (vec *command-line-args*)
                             expr (str "(require '[bb.test-tasks :as t]) "
                                       "(binding [t/*step-globs* "
                                       "[\"isaac.**-steps\" \"isaac.cli-proxy.feature-bootstrap\"]] "
                                       "(apply t/run-features-slow! *command-line-args*))")
                             cmd  (into ["bb" "-e" expr "--"] args)
                             {:keys [exit]} (apply process/shell cmd)]
                         (when (pos? exit) (System/exit exit)))}

  jvm-features {:doc  "Run gherclj via clojure -M:features (JVM fallback)"
                :requires ([bb.test-tasks :as tests])
                :task (binding [tests/*jvm-features-cmd* ["clojure" "-M:features"]]
                        (apply tests/run-jvm-features! *command-line-args*))}

  ci {:doc  "Native specs + features + slow features"
      :requires ([babashka.process :as process])
      :task (do (run 'config-bypass-lint)
                (doseq [t ["spec" "features" "features-slow"]]
                  (let [{:keys [exit]} (process/shell "bb" t)]
                    (when (pos? exit) (System/exit exit)))))}

  clean {:doc  "Remove the target/ build dir"
         :task (babashka.fs/delete-tree "target")}}}
